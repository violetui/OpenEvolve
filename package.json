{
  "name": "open-evolve",
  "module": "src/main.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/main.ts",
    "test": "bun test",
    "check": "bun run tsc --noEmit",
    "smoke": "bun run src/main.ts &sleep 2 && curl -s http://localhost:3000/health && kill %1",
    "compile": "bun build src/main.ts --outdir dist --target bun"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "openai": "^5",
    "playwright": "^1.60.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
